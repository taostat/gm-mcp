{
  "name": "goodmorning-mcp",
  "version": "0.1.1",
  "description": "MCP server exposing the gm (saygm.com) inference gateway's models as callable tools for coding agents",
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gm",
    "saygm",
    "llm",
    "inference",
    "codex",
    "claude-code"
  ],
  "homepage": "https://github.com/taostat/gm-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taostat/gm-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/taostat/gm-mcp/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "goodmorning-mcp": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "oxlint": "1.74.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
